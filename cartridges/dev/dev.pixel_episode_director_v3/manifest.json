{
  "schema_version": "1.0",
  "id": "dev.pixel_episode_director_v3",
  "name": "像素短剧协作工厂卡带 v3.0",
  "version": "3.0.0-dev",
  "kind": "runtime_cartridge",
  "category": "dev_flow",
  "description": "基于 CF-FARP@0.4 重写的像素短剧协作工厂：用户与 AI 先并行确认故事节拍、素材建设和运镜方案，通过后再汇总生成镜头表、调用 Godot 舞台出片，并整理交付物。",
  "publisher": {
    "id": "local",
    "name": "Local Developer",
    "type": "local",
    "verified": false
  },
  "branding": {
    "tags": [
      "pixel",
      "episode",
      "2.5d",
      "godot",
      "video",
      "cf-farp",
      "protocol-aware",
      "protocol-v0.4",
      "cf-farp-0-4-certified"
    ]
  },
  "root_flow": {
    "entry": "root.flow.json",
    "mode": "lifecycle",
    "required": true
  },
  "runtime": {
    "type": "lab",
    "adapter": "builtin:lab"
  },
  "workspace": {
    "type": "none",
    "required": false,
    "open_policy": "manual"
  },
  "environment": {
    "os": [
      "windows",
      "macos",
      "linux"
    ],
    "requires": [
      {
        "id": "godot",
        "type": "command",
        "command": "godot",
        "description": "可选但推荐。检测到 Godot 4 Movie Maker 时使用原生渲染；不可用时回退到本地 Python 像素舞台 AVI。"
      },
      {
        "id": "ffmpeg",
        "type": "command",
        "command": "ffmpeg",
        "description": "可选。用于把渲染产物合成为浏览器可直接预览的 MP4；不可用时保留 AVI 产物。"
      }
    ]
  },
  "permissions": [
    {
      "id": "read_cartridge_assets",
      "level": "safe",
      "description": "读取卡带内 series_bible、world_state、shot_presets 和 asset_manifest。"
    },
    {
      "id": "write_run_artifacts",
      "level": "safe",
      "description": "写入 test_output/pixel_episode_v3 下的镜头表、校验报告、渲染包、视频和预览页。"
    },
    {
      "id": "write_draft_assets",
      "level": "sensitive",
      "description": "写入 assets/pixel_stage/drafts，并更新 asset_manifest.json 的 draft_assets；不得自动提升为 approved_assets。"
    },
    {
      "id": "write_world_state",
      "level": "sensitive",
      "description": "仅在用户将 continuity_policy 设置为 read_and_write 时回写 assets/world_state.json。"
    }
  ],
  "dependencies": [
    {
      "id": "godot",
      "type": "system_package",
      "description": "Godot 4，用于原生渲染像素片场 AVI。未安装时流程会使用本地 Python fallback。",
      "install": {
        "strategy": "manual"
      }
    },
    {
      "id": "ffmpeg",
      "type": "system_package",
      "description": "FFmpeg，用于 MP4 合成。未安装或用户关闭合成时保留渲染源视频。",
      "install": {
        "strategy": "manual"
      }
    }
  ],
  "mcp_tools": [
    {
      "id": "filesystem_read",
      "name": "Filesystem 读取文件",
      "type": "builtin",
      "server": "filesystem",
      "tool": "read_file",
      "description": "读取卡带内的系列设定、连续性状态、镜头预设和资产清单。",
      "default_params": {
        "path": "cartridges/dev/dev.pixel_episode_director_v3/assets/series_bible.json\ncartridges/dev/dev.pixel_episode_director_v3/assets/world_state.json\ncartridges/dev/dev.pixel_episode_director_v3/assets/shot_presets.json\ncartridges/dev/dev.pixel_episode_director_v3/assets/asset_manifest.json"
      },
      "enabled": true,
      "required": true,
      "contract": {
        "capability": "builtin_tool_call",
        "idempotent": true,
        "side_effect": "none",
        "timeout_ms": 5000,
        "retry_policy": {
          "max_attempts": 1
        }
      },
      "params_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    {
      "id": "media_probe",
      "name": "Media 环境探测",
      "type": "builtin",
      "server": "media",
      "tool": "probe",
      "description": "探测本地 media provider 可用性，包括本地 Python、FFmpeg、ComfyUI 和 Godot。",
      "default_params": {
        "providers": "local,ffmpeg,comfyui,godot",
        "comfyui_url": "http://127.0.0.1:8188"
      },
      "enabled": true,
      "required": true,
      "contract": {
        "capability": "builtin_tool_call",
        "idempotent": true,
        "side_effect": "environment_probe",
        "timeout_ms": 10000,
        "retry_policy": {
          "max_attempts": 1
        }
      },
      "params_schema": {
        "type": "object",
        "properties": {},
        "additionalProperties": true
      }
    },
    {
      "id": "media_check_pixel_assets",
      "name": "Media 像素资产门禁",
      "type": "builtin",
      "server": "media",
      "tool": "check_pixel_assets",
      "description": "检查正式生产是否只使用已批准角色、地点和资产 profile。",
      "enabled": true,
      "required": true,
      "contract": {
        "capability": "builtin_tool_call",
        "idempotent": true,
        "side_effect": "writes_run_artifacts",
        "timeout_ms": 30000,
        "retry_policy": {
          "max_attempts": 1
        }
      },
      "params_schema": {
        "type": "object",
        "properties": {
          "series_bible_path": {
            "type": "string"
          },
          "asset_manifest_path": {
            "type": "string"
          },
          "output_path": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    {
      "id": "media_forge_pixel_asset_batch",
      "name": "Media 像素素材草稿工坊",
      "type": "builtin",
      "server": "media",
      "tool": "forge_pixel_asset_batch",
      "description": "消费 AI 生成的 asset_spec_batch.v1，生成角色、地点、背景或道具草稿，并写入 draft_assets 等待复核。",
      "enabled": true,
      "required": true,
      "contract": {
        "capability": "builtin_tool_call",
        "idempotent": false,
        "side_effect": "writes_draft_assets_and_manifest",
        "timeout_ms": 120000,
        "retry_policy": {
          "max_attempts": 1
        }
      },
      "params_schema": {
        "type": "object",
        "properties": {
          "asset_specs": {
            "type": "string"
          },
          "asset_policy": {
            "type": "string"
          },
          "output_dir": {
            "type": "string"
          },
          "asset_manifest_path": {
            "type": "string"
          },
          "report_path": {
            "type": "string"
          },
          "comfyui_url": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    {
      "id": "media_generate_pixel_shot_plan",
      "name": "Media 生成像素镜头表",
      "type": "builtin",
      "server": "media",
      "tool": "generate_pixel_shot_plan",
      "description": "根据用户入料、连续性状态和镜头预设生成可执行镜头表 JSON。",
      "enabled": true,
      "required": true,
      "contract": {
        "capability": "builtin_tool_call",
        "idempotent": true,
        "side_effect": "writes_run_artifacts",
        "timeout_ms": 30000,
        "retry_policy": {
          "max_attempts": 1
        }
      },
      "params_schema": {
        "type": "object",
        "properties": {
          "episode_id": {
            "type": "string"
          },
          "episode_goal": {
            "type": "string"
          },
          "style_notes": {
            "type": "string"
          },
          "shot_count": {
            "type": "string"
          },
          "output_path": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    {
      "id": "media_validate_pixel_shot_plan",
      "name": "Media 校验像素镜头表",
      "type": "builtin",
      "server": "media",
      "tool": "validate_pixel_shot_plan",
      "description": "校验镜头表是否符合系列设定、资产清单和 Camera2D 预设。",
      "enabled": true,
      "required": true,
      "contract": {
        "capability": "builtin_tool_call",
        "idempotent": true,
        "side_effect": "writes_run_artifacts",
        "timeout_ms": 30000,
        "retry_policy": {
          "max_attempts": 1
        }
      },
      "params_schema": {
        "type": "object",
        "properties": {
          "shot_plan_path": {
            "type": "string"
          },
          "series_bible_path": {
            "type": "string"
          },
          "asset_manifest_path": {
            "type": "string"
          },
          "output_path": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    {
      "id": "media_godot_render_pixel_episode",
      "name": "Media Godot 像素短剧渲染",
      "type": "builtin",
      "server": "media",
      "tool": "godot_render_pixel_episode",
      "description": "按镜头表渲染像素 2.5D 帧序列和本地视频包。",
      "enabled": true,
      "required": true,
      "contract": {
        "capability": "builtin_tool_call",
        "idempotent": false,
        "side_effect": "writes_video_frames_and_run_artifacts",
        "timeout_ms": 240000,
        "retry_policy": {
          "max_attempts": 1
        }
      },
      "params_schema": {
        "type": "object",
        "properties": {
          "shot_plan_path": {
            "type": "string"
          },
          "output_dir": {
            "type": "string"
          },
          "filename_prefix": {
            "type": "string"
          },
          "require_godot_native": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    {
      "id": "media_ffmpeg_mux_episode",
      "name": "Media FFmpeg 短片合成",
      "type": "builtin",
      "server": "media",
      "tool": "ffmpeg_mux_episode",
      "description": "把渲染产物合成为 MP4，并生成浏览器预览页；FFmpeg 不可用时保留 AVI。",
      "enabled": true,
      "required": true,
      "contract": {
        "capability": "builtin_tool_call",
        "idempotent": true,
        "side_effect": "writes_video_preview_artifacts",
        "timeout_ms": 180000,
        "retry_policy": {
          "max_attempts": 1
        }
      },
      "params_schema": {
        "type": "object",
        "properties": {
          "video_path": {
            "type": "string"
          },
          "output_path": {
            "type": "string"
          },
          "preview_path": {
            "type": "string"
          },
          "compose_provider": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    {
      "id": "media_update_pixel_world_state",
      "name": "Media 连续性状态回写",
      "type": "builtin",
      "server": "media",
      "tool": "update_pixel_world_state",
      "description": "短片完成后根据 continuity_policy 更新或跳过 world_state.json。",
      "enabled": true,
      "required": true,
      "contract": {
        "capability": "builtin_tool_call",
        "idempotent": false,
        "side_effect": "writes_persistent_world_state_when_policy_allows",
        "timeout_ms": 30000,
        "retry_policy": {
          "max_attempts": 1
        }
      },
      "params_schema": {
        "type": "object",
        "properties": {
          "world_state_path": {
            "type": "string"
          },
          "shot_plan_path": {
            "type": "string"
          },
          "episode_id": {
            "type": "string"
          },
          "continuity_policy": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  ],
  "inputs": [
    {
      "id": "project_brief",
      "label": "项目简述",
      "type": "textarea",
      "required": true,
      "default": "2.5D 像素短剧，夜市闪灯引出下一集悬念。",
      "placeholder": "描述本集短剧类型、情绪、观众预期和交付要求"
    },
    {
      "id": "episode_id",
      "label": "集编号",
      "type": "text",
      "required": true,
      "default": "ep_factory_v3",
      "placeholder": "例如 ep_004"
    },
    {
      "id": "episode_goal",
      "label": "本集目标",
      "type": "textarea",
      "required": true,
      "default": "主角在夜市小巷发现异常闪灯，结尾留下追踪者线索。",
      "placeholder": "这一集必须完成的剧情推进"
    },
    {
      "id": "source_materials",
      "label": "剧情原料",
      "type": "textarea",
      "required": false,
      "default": "角色：hero、vendor；地点：night_alley；道具：flicker_sign。",
      "placeholder": "角色、地点、道具、对白或参考片段"
    },
    {
      "id": "story_requests",
      "label": "故事节拍偏好",
      "type": "textarea",
      "required": false,
      "default": "四段式悬念：建立夜市、发现异常、线索特写、留下追踪者钩子。",
      "placeholder": "描述希望 AI 如何安排剧情节拍、情绪递进和结尾钩子"
    },
    {
      "id": "asset_requests",
      "label": "素材制作要求",
      "type": "textarea",
      "required": false,
      "default": "生成一个蓝色衬衫的人物角色草稿，动作包含 idle、walk_right、talk_idle；保持 2.5D 像素短剧风格。",
      "placeholder": "例如：蓝色衬衫的人物、霓虹招牌道具、雨夜小巷背景草稿"
    },
    {
      "id": "camera_requests",
      "label": "运镜偏好",
      "type": "textarea",
      "required": false,
      "default": "低机位，轻微视差；先建立空间，再跟拍靠近，随后特写闪灯，最后推近到远处人影。",
      "placeholder": "描述镜头运动、构图、节奏、视角和重点镜头"
    },
    {
      "id": "style_notes",
      "label": "风格配方",
      "type": "textarea",
      "required": false,
      "default": "低机位、轻微视差、像素霓虹、镜头节奏 4-6 秒。",
      "placeholder": "画面、镜头、节奏、音乐或色彩要求"
    },
    {
      "id": "shot_count",
      "label": "镜头数",
      "type": "text",
      "required": false,
      "default": "4",
      "placeholder": "3-6"
    },
    {
      "id": "target_product",
      "label": "目标产物",
      "type": "select",
      "required": false,
      "default": "mp4",
      "options": [
        {
          "value": "mp4",
          "label": "MP4 短片"
        },
        {
          "value": "preview",
          "label": "浏览器预览"
        },
        {
          "value": "render_bundle",
          "label": "渲染包"
        }
      ]
    },
    {
      "id": "continuity_policy",
      "label": "连续性策略",
      "type": "select",
      "required": false,
      "default": "read_only",
      "options": [
        {
          "value": "read_only",
          "label": "只读连续状态"
        },
        {
          "value": "read_and_write",
          "label": "读取并回写"
        },
        {
          "value": "off",
          "label": "关闭连续性"
        }
      ]
    },
    {
      "id": "asset_policy",
      "label": "资产策略",
      "type": "select",
      "required": false,
      "default": "draft_allowed",
      "options": [
        {
          "value": "approved_only",
          "label": "仅用已批准资产"
        },
        {
          "value": "draft_allowed",
          "label": "允许生成草稿资产"
        },
        {
          "value": "ask_before_forge",
          "label": "缺料时先询问"
        }
      ]
    },
    {
      "id": "output_dir",
      "label": "出料目录",
      "type": "text",
      "required": false,
      "default": "test_output/pixel_episode_v3",
      "placeholder": "test_output/pixel_episode_v3"
    },
    {
      "id": "compose_provider",
      "label": "视频合成",
      "type": "select",
      "required": false,
      "default": "ffmpeg",
      "options": [
        {
          "value": "ffmpeg",
          "label": "FFmpeg MP4"
        },
        {
          "value": "local",
          "label": "保留本地 AVI"
        },
        {
          "value": "off",
          "label": "不合成"
        }
      ]
    },
    {
      "id": "comfyui_url",
      "label": "ComfyUI 地址",
      "type": "text",
      "required": false,
      "default": "http://127.0.0.1:8188",
      "placeholder": "http://127.0.0.1:8188"
    }
  ],
  "outputs": [
    {
      "id": "episode_delivery",
      "label": "短剧工程交付汇总",
      "type": "json",
      "required": true
    },
    {
      "id": "episode_video",
      "label": "短片视频产物",
      "type": "json",
      "required": false
    },
    {
      "id": "render_bundle",
      "label": "Godot 渲染包",
      "type": "json",
      "required": false
    }
  ],
  "artifacts": {
    "store_policy": "run_scoped",
    "visibility_default": "user",
    "allowed_types": [
      "video",
      "html",
      "json",
      "image",
      "text"
    ]
  },
  "delivery": {
    "type": "summary_with_artifacts",
    "primary_output": "episode_delivery",
    "show_artifacts": true
  },
  "base_contract": {
    "id": "CF-FARP",
    "version": "0.4",
    "declared_for": "cartridgeflow.reference-dev",
    "compatibility_mode": "protocol_aware"
  },
  "runtime_contract": {
    "protocol": "CF-FARP",
    "protocol_version": "0.4",
    "required_profiles": [
      "runtime_core",
      "dynamic_decision_runtime",
      "interactive_decision_runtime"
    ],
    "recommended_profiles": [
      "testbench_core",
      "dev_authoring"
    ],
    "required_capabilities": [
      "manifest_load",
      "manifest_validate",
      "runtime_contract_parse",
      "compatibility_report",
      "root_flow_execution",
      "basic_node_execution",
      "unified_process_node",
      "process_node_kind_parse",
      "process_executor_contract",
      "process_effect_contract",
      "transfer_process",
      "decision_process",
      "mcp_read_process",
      "mcp_execute_process",
      "process_mcp_readonly_binding",
      "decision_envelope_v1",
      "decision_envelope_validate",
      "decision_consume_contract",
      "decision_consume_projection",
      "llm_live_mode",
      "llm_mock_mode",
      "llm_offline_fallback",
      "runtime_user_input_request",
      "paused_waiting_user_status",
      "pending_interaction_record",
      "runtime_resume_after_user_input",
      "builtin_tool_call",
      "artifact_collect",
      "data_chain_diagnostics",
      "delivery_readiness_check",
      "optional_input"
    ],
    "optional_capabilities": [
      "artifact_preview",
      "testbench_run",
      "probe_run",
      "structure_analysis"
    ],
    "required_tools": [
      "filesystem_read",
      "media_probe",
      "media_check_pixel_assets",
      "media_forge_pixel_asset_batch",
      "media_generate_pixel_shot_plan",
      "media_validate_pixel_shot_plan",
      "media_godot_render_pixel_episode",
      "media_ffmpeg_mux_episode",
      "media_update_pixel_world_state"
    ],
    "optional_tools": []
  },
  "delivery_readiness": {
    "level": "dev",
    "runnable": true,
    "certification_target": "CF-FARP@0.4",
    "notes": "v2.0 是协议化工程底稿。默认连续性策略为 read_only，避免测试运行修改原始 world_state；用户显式选择 read_and_write 后才允许回写。"
  },
  "protocol_certification": {
    "status": "certified",
    "label": "cf-farp-0-4-certified",
    "protocol": "CF-FARP",
    "protocol_version": "0.4",
    "base_implementation_id": "cartridgeflow.reference-dev",
    "base_implementation_version": "0.1.0"
  }
}

