      },
      "mock_decision_envelope": {
        "schema": "decision_envelope.v1",
        "status": "resolved",
        "summary": "Mock：项目方向已确认。",
        "payload": {
          "direction": {
            "schema": "project_direction.v1",
            "approved": true,
            "goal": "并行规划故事、素材和运镜，汇总后生成 Godot 短剧。",
            "collaboration_policy": "ask_before_high_freedom_side_effect",
            "mock": true
          }
        }
      },
      "params": {
        "model_role": "runtime",
        "system_prompt": "你是像素短剧协作工厂的项目导演。你必须只输出 decision_envelope.v1 JSON，不要输出额外文本。",
        "prompt": "请确认用户作品目标是否足够进入协作规划。若信息不足，输出 needs_user_input，并询问缺失的剧情目标、素材方向、运镜偏好或交付目标。若足够，输出 resolved，并在 payload.direction 中给出 project_direction.v1：{schema, approved, goal, collaboration_policy, constraints[], risks[]}。不得执行工具副作用。",
        "description": "确认项目方向，缺失时向用户追问。",
        "input": "episode_brief",
        "optional_input": "project_direction_reply",
        "output": "project_direction_decision"
