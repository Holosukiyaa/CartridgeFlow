    "review_draft_assets": {
      "type": "process",
      "title": "AI决策：素材草稿复核",
      "kind": "decision",
      "executor": "llm",
      "effect": "none",
      "protocol_version": "0.4",
      "display": {
        "suffix": "AI决策",
        "label": "AI决策节点"
      },
      "input": "episode_brief,asset_specs_payload,draft_asset_bundle",
      "output": "asset_review_decision",
      "output_contract": "decision_envelope.v1",
      "decision_contract": {
        "schema": "decision_envelope.v1",
        "allowed_statuses": [
          "resolved",
          "needs_user_input",
          "blocked"
        ],
        "on_needs_user_input": "pause",
        "interaction": {
          "store_key": "asset_review_reply",
          "input_schema": {
            "type": "object",
            "properties": {
              "approval": {
                "type": "string",
                "title": "复核动作",
                "enum": [
                  "approve",
                  "revise"
                ],
                "description": "approve 表示满意继续，revise 表示不满意并重新生成。"
              },
              "feedback": {
                "type": "string",
                "title": "修改意见",
                "description": "不满意时写清楚颜色、动作、轮廓、风格、数量或具体素材修改要求。"
              }
            },
            "required": [
              "approval"
            ]
          },
          "resume_policy": "resume_same_node",
          "live_collaboration": true,
          "answer_routes": [
            {
              "match": {
                "field": "approval",
                "equals": "revise"
              },
              "policy": "resume_target_node",
              "target_node": "plan_asset_specs",
              "replay_from_target": true,
              "copy_answer_to": "asset_rework_feedback",
              "clear_store_keys": [
                "asset_review_reply",
                "asset_review_decision",
                "asset_review_payload",
                "asset_specs_decision",
                "asset_specs_payload",
                "draft_asset_bundle",
                "creation_packet",
                "shot_plan_json",
                "validation_report",
                "render_approval_decision",
                "render_approval_payload",
                "render_bundle",
                "episode_video"
              ]
            },
            {
              "match": {
                "contains_any": [
                  "不满意",
                  "重做",
                  "重新生成",
                  "修改",
                  "revise",
                  "regenerate"
                ]
              },
              "policy": "resume_target_node",
              "target_node": "plan_asset_specs",
              "replay_from_target": true,
              "copy_answer_to": "asset_rework_feedback",
              "clear_store_keys": [
                "asset_review_reply",
                "asset_review_decision",
                "asset_review_payload",
                "asset_specs_decision",
                "asset_specs_payload",
                "draft_asset_bundle",
                "creation_packet",
                "shot_plan_json",
                "validation_report",
                "render_approval_decision",
                "render_approval_payload",
                "render_bundle",
                "episode_video"
              ]
            }
          ]
        },
        "offline_decision": {
          "schema": "decision_envelope.v1",
          "status": "resolved",
          "summary": "离线兜底：素材草稿复核通过，可进入镜头表生成。",
          "payload": {
            "review": {
              "schema": "asset_review.v1",
              "approved": true,
              "approved_for_planning": true,
              "approved_for_production": false,
              "source": "offline_fallback"
            }
          }
        },
        "consume": {
          "mode": "payload_path",
          "path": "payload.review",
          "as": "asset_review_payload",
          "required": true,
          "on_missing": "fail_closed"
        }
      },
      "mock_decision_envelope": {
        "schema": "decision_envelope.v1",
        "status": "resolved",
        "summary": "Mock：素材草稿复核通过。",
        "payload": {
          "review": {
            "schema": "asset_review.v1",
            "approved": true,
            "approved_for_planning": true,
            "approved_for_production": false,
            "mock": true
          }
        }
      },
      "params": {
        "model_role": "runtime",
        "system_prompt": "你是像素短剧素材草稿复核节点。你必须只输出 decision_envelope.v1 JSON，不要输出额外文本。",
        "prompt": "这是生成后的用户复核节点。若 optional_input asset_review_reply 不存在，必须输出 needs_user_input，让用户查看 draft_asset_bundle 后选择 approve 或 revise；resume.policy 必须是 resume_same_node，并带 answer_routes：approval=revise 或文本包含不满意/重做/重新生成/修改时，resume_target_node 到 plan_asset_specs，replay_from_target=true，copy_answer_to=asset_rework_feedback，clear_store_keys 至少清理 asset_review_reply、asset_review_payload、asset_specs_payload、draft_asset_bundle、creation_packet、shot_plan_json。若 optional_input asset_review_reply 表示 approve 或满意，输出 resolved，并在 payload.review 中提供 asset_review.v1：{schema, approved, approved_for_planning, approved_for_production, notes}。草稿不得自动转正为 approved_assets。",
        "description": "让用户查看已生成素材草稿；不满意时回到素材规格节点并带反馈重新生成。",
        "input": "episode_brief,asset_specs_payload,draft_asset_bundle",
        "optional_input": "asset_review_reply",
        "output": "asset_review_decision"
      },
