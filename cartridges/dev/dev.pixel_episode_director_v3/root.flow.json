        "schema": "decision_envelope.v1",
        "allowed_statuses": [
          "resolved",
          "needs_user_input",
          "blocked"
        ],
        "on_needs_user_input": "pause",
        "interaction": {
          "store_key": "project_direction_reply",
          "input_schema": {
            "type": "object",
            "properties": {
              "answer": {
                "type": "string",
                "title": "方向确认",
                "description": "确认方向，或补充必须保留/禁止的内容。"
              }
            },
            "required": [
              "answer"
            ]
          },
          "resume_policy": "resume_same_node",
          "live_collaboration": true
        },
        "offline_decision": {
          "schema": "decision_envelope.v1",
          "status": "resolved",
          "summary": "离线兜底：项目方向足够清晰，可以进入协作规划。",
          "payload": {
            "direction": {
              "schema": "project_direction.v1",
              "approved": true,
              "goal": "制作一集 2.5D 像素短剧，先并行规划故事、素材和运镜，再汇总生成 Godot 成品。",
              "collaboration_policy": "ask_before_high_freedom_side_effect",
              "source": "offline_fallback"
            }
          }
        },
        "consume": {
          "mode": "payload_path",
          "path": "payload.direction",
          "as": "project_direction_payload",
          "required": true,
          "on_missing": "fail_closed"
