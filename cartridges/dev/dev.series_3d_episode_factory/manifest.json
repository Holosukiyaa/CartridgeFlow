{
  "schema_version": "1.0",
  "id": "dev.series_3d_episode_factory",
  "name": "3D 系列短剧分镜工厂",
  "version": "0.5.0-dev",
  "kind": "runtime_cartridge",
  "category": "dev_flow",
  "description": "先把文本拆成可编辑的分镜，再把确认后的镜头交给图像与视频模型。卡带拥有自己的导演台、工具和协议扩展。",
  "publisher": {"id": "local", "name": "Local Developer", "type": "local", "verified": false},
  "branding": {"tags": ["3d", "series", "storyboard", "director-console", "wan2.2", "cf-farp-0.5", "portable-dlc"]},
  "base_contract": {"id": "CF-FARP", "version": "0.5", "declared_for": "cartridgeflow.reference-dev", "compatibility_mode": "protocol_aware"},
  "runtime_contract": {
    "protocol": "CF-FARP", "protocol_version": "0.5",
    "required_profiles": ["runtime_core", "dynamic_decision_runtime", "interactive_decision_runtime", "portable_dlc_runtime"],
    "recommended_profiles": ["testbench_core", "dev_authoring"],
    "required_capabilities": ["manifest_load", "manifest_validate", "runtime_contract_parse", "compatibility_report", "root_flow_execution", "basic_node_execution", "unified_process_node", "multi_input_node", "process_node_kind_parse", "process_executor_contract", "process_effect_contract", "decision_process", "mcp_read_process", "mcp_execute_process", "process_mcp_readonly_binding", "decision_envelope_v1", "decision_envelope_validate", "decision_consume_contract", "decision_consume_projection", "llm_live_mode", "llm_mock_mode", "llm_offline_fallback", "runtime_user_input_request", "paused_waiting_user_status", "pending_interaction_record", "runtime_resume_after_user_input", "builtin_tool_call", "artifact_collect", "delivery_readiness_check", "optional_input", "portable_dlc_descriptor", "portable_dlc_validate", "cartridge_scoped_tool_registry", "isolated_dlc_worker", "dlc_worker_json_rpc", "cartridge_protocol_overlay", "frontend_dlc_sandbox", "package_owned_code", "dlc_activation_lifecycle", "dlc_uninstall_cleanup", "dlc_absence_verification", "dlc_resource_ownership", "dlc_artifact_retention_policy", "dlc_integrity_hash"],
    "optional_capabilities": ["artifact_preview", "testbench_run", "probe_run", "structure_analysis", "data_chain_diagnostics"],
    "required_tools": ["media_match_series_assets", "media_match_series_actions", "build_storyboard_project", "render_storyboard_frames", "apply_storyboard_adjustments", "prepare_video_shots"],
    "optional_tools": ["forge_3d_series_episode"]
  },
  "protocol_certification": {"status": "certified", "label": "CF-FARP@0.5", "protocol": "CF-FARP", "protocol_version": "0.5"},
  "delivery_readiness": {"level": "dev", "certification_target": "CF-FARP@0.5", "notes": "分镜项目、导演调整记录、确认后的镜头包和基础帧是本卡带的主交付物。"},
  "root_flow": {"entry": "root.flow.json", "mode": "lifecycle", "required": true},
  "runtime": {"type": "lab", "adapter": "builtin:lab"},
  "workspace": {"type": "none", "required": false, "open_policy": "manual"},
  "environment": {"os": ["windows", "macos", "linux"], "requires": []},
  "permissions": [{"id": "write_run_artifacts", "level": "safe"}],
  "inputs": [{"id": "episode_brief", "label": "本集创作需求", "type": "textarea", "required": true, "placeholder": "人物、冲突、场景和希望观众看到的结果"}],
  "outputs": [{"id": "series_delivery", "type": "storyboard_delivery", "description": "已确认的分镜项目和视频镜头包"}],
  "mcp_tools": [
    {"id": "media_match_series_assets", "name": "匹配固定资产", "type": "builtin", "server": "media", "tool": "match_series_assets", "required": true, "enabled": true, "description": "将剧情和分镜映射到卡带固定资产库。", "contract": {"capability": "builtin_tool_call", "side_effect": "read_only", "timeout_ms": 30000, "idempotent": true}},
    {"id": "media_match_series_actions", "name": "匹配动作与摄影机", "type": "builtin", "server": "media", "tool": "match_series_actions", "required": true, "enabled": true, "description": "将动作标签和镜头模板映射到固定动作库。", "contract": {"capability": "builtin_tool_call", "side_effect": "read_only", "timeout_ms": 30000, "idempotent": true}},
    {"id": "build_storyboard_project", "name": "构建分镜项目", "type": "builtin", "server": "media", "tool": "build_storyboard_project", "required": true, "enabled": true, "description": "从剧情、分镜和资产计划建立可编辑分镜项目。", "contract": {"capability": "builtin_tool_call", "side_effect": "writes_run_artifacts", "timeout_ms": 30000, "idempotent": true}},
    {"id": "render_storyboard_frames", "name": "生成分镜帧", "type": "builtin", "server": "media", "tool": "render_storyboard_frames", "required": true, "enabled": true, "description": "为每个镜头生成稳定的基础构图帧。", "contract": {"capability": "builtin_tool_call", "side_effect": "writes_run_artifacts", "timeout_ms": 30000, "idempotent": true}},
    {"id": "apply_storyboard_adjustments", "name": "保存导演调整", "type": "builtin", "server": "media", "tool": "apply_storyboard_adjustments", "required": true, "enabled": true, "description": "保存导演对镜头、人物、灯光和提示词的调整与确认。", "contract": {"capability": "builtin_tool_call", "side_effect": "writes_run_artifacts", "timeout_ms": 30000, "idempotent": true}},
    {"id": "prepare_video_shots", "name": "生成视频镜头包", "type": "builtin", "server": "media", "tool": "prepare_video_shots", "required": true, "enabled": true, "description": "仅在所有分镜确认后生成 Wan 视频阶段的镜头包。", "contract": {"capability": "builtin_tool_call", "side_effect": "writes_run_artifacts", "timeout_ms": 30000, "idempotent": true}},
    {"id": "forge_3d_series_episode", "name": "Blender 预演", "type": "builtin", "server": "media", "tool": "forge_3d_series_episode", "required": false, "enabled": false, "description": "可选的旧版 Blender 预演工具，不属于分镜闭环。", "contract": {"timeout_ms": 300000, "idempotent": false}}
  ],
  "portable_dlc": {"protocol": "CF-FARP@0.5", "descriptor": "dlc/descriptor.json", "activation": "manifest_scoped", "uninstall": {"remove_package_owned_code": true, "remove_private_data": true, "preserve_user_artifacts": true}}
}
