{
  "schema_version": 1,
  "id": "dev.series_3d_episode_factory.root.v2",
  "name": "3D 系列短剧分镜工作流",
  "mode": "lifecycle",
  "cartridge_id": "dev.series_3d_episode_factory",
  "protocol": {
    "id": "CF-FARP",
    "version": "0.5"
  },
  "start": "start",
  "states": {
    "start": {
      "type": "system",
      "title": "开始",
      "action": "start",
      "next": "collect_brief",
      "layout": {
        "x": 9,
        "y": 239
      }
    },
    "collect_brief": {
      "type": "process",
      "title": "填写创作需求",
      "kind": "input",
      "executor": "user",
      "effect": "writes_store",
      "protocol_version": "0.5",
      "input_kind": "episode_brief",
      "source": "run_inputs",
      "output": "episode_inputs",
      "input_schema": {
        "type": "object",
        "fields": [
          "episode_brief"
        ]
      },
      "params": {
        "description": "输入本集的故事想法。",
        "fields": [
          "episode_brief"
        ],
        "output": "episode_inputs"
      },
      "next": "write_script",
      "layout": {
        "x": 260,
        "y": 240
      }
    },
    "write_script": {
      "type": "process",
      "title": "AI 生成剧情",
      "kind": "decision",
      "executor": "llm",
      "effect": "none",
      "protocol_version": "0.5",
      "input": "episode_inputs",
      "optional_input": "script_reply",
      "output": "episode_script_decision",
      "output_contract": "decision_envelope.v1",
      "decision_contract": {
        "schema": "decision_envelope.v1",
        "allowed_statuses": [
          "resolved",
          "needs_user_input",
          "blocked"
        ],
        "on_needs_user_input": "pause",
        "interaction": {
          "store_key": "script_reply",
          "input_schema": {
            "type": "object",
            "properties": {
              "approval": {
                "type": "string",
                "enum": [
                  "approve",
                  "revise"
                ]
              },
              "feedback": {
                "type": "string"
              }
            },
            "required": [
              "approval"
            ]
          },
          "resume_policy": "resume_same_node",
          "live_collaboration": true
        },
        "consume": {
          "mode": "payload_path",
          "path": "payload.episode_script",
          "as": "episode_script",
          "on_missing": "fail_closed"
        },
        "offline_decision": {
          "schema": "decision_envelope.v1",
          "status": "resolved",
          "summary": "离线剧情草案",
          "payload": {
            "episode_script": {
              "schema": "episode_script.v1",
              "title": "街角的回声",
              "episode_id": "pilot_suburban_ep01",
              "genre": "urban_suspense",
              "format": "vertical_short",
              "duration_target": 30,
              "hook": "男孩在空街上听见第二个脚步声。",
              "logline": "一个男孩沿着白天的街道前进，停下后发现声音来自自己的影子。",
              "beats": [
                "男孩向前走过街道",
                "他停下观察四周",
                "影子做出不同步的动作"
              ],
              "dialogue": [],
              "ending_hook": "影子先一步走进拐角"
            }
          }
        }
      },
      "params": {
        "description": "只生成剧情和节奏，不生成美术资产。",
        "system_prompt": "你是系列短剧编剧。只输出 decision_envelope.v1 的 episode_script.v1。",
        "prompt": "根据 episode_inputs 生成 episode_script.v1。",
        "input": "episode_inputs",
        "optional_input": "script_reply",
        "output": "episode_script_decision",
        "output_contract": "decision_envelope.v1"
      },
      "next": "plan_shots",
      "layout": {
        "x": 500,
        "y": 240
      }
    },
    "plan_shots": {
      "type": "process",
      "title": "AI 拆解分镜",
      "kind": "decision",
      "executor": "llm",
      "effect": "none",
      "protocol_version": "0.5",
      "input": "episode_inputs,episode_script",
      "optional_input": "shot_reply",
      "output": "shot_list_decision",
      "output_contract": "decision_envelope.v1",
      "decision_contract": {
        "schema": "decision_envelope.v1",
        "allowed_statuses": [
          "resolved",
          "needs_user_input",
          "blocked"
        ],
        "on_needs_user_input": "pause",
        "interaction": {
          "store_key": "shot_reply",
          "input_schema": {
            "type": "object",
            "properties": {
              "approval": {
                "type": "string",
                "enum": [
                  "approve",
                  "revise"
                ]
              },
              "feedback": {
                "type": "string"
              }
            },
            "required": [
              "approval"
            ]
          },
          "resume_policy": "resume_same_node",
          "live_collaboration": true
        },
        "consume": {
          "mode": "payload_path",
          "path": "payload.shot_list",
          "as": "shot_list",
          "on_missing": "fail_closed"
        },
        "offline_decision": {
          "schema": "decision_envelope.v1",
          "status": "resolved",
          "summary": "离线分镜草案",
          "payload": {
            "shot_list": {
              "schema": "shot_list.v1",
              "shots": [
                {
                  "id": "shot_01",
                  "title": "街道前进",
                  "description": "男孩沿着白天的郊区街道向前走。",
                  "scene": "白天郊区街道",
                  "characters": [
                    "hero"
                  ],
                  "props": [],
                  "action_tags": [
                    "walk_slow"
                  ],
                  "camera": "slow_push_in",
                  "duration": 5
                },
                {
                  "id": "shot_02",
                  "title": "停下观察",
                  "description": "男孩停下脚步，侧头听向身后。",
                  "scene": "白天郊区街道",
                  "characters": [
                    "hero"
                  ],
                  "props": [],
                  "action_tags": [
                    "idle_hold"
                  ],
                  "camera": "close_up_reveal",
                  "duration": 5
                },
                {
                  "id": "shot_03",
                  "title": "影子异动",
                  "description": "男孩抬头，影子在地面上先一步转向拐角。",
                  "scene": "白天郊区街道",
                  "characters": [
                    "hero"
                  ],
                  "props": [],
                  "action_tags": [
                    "gesture_interact"
                  ],
                  "camera": "low_angle_hold",
                  "duration": 5
                }
              ]
            }
          }
        }
      },
      "params": {
        "description": "以镜头为单位生成可编辑的构图、动作和节奏草案。",
        "system_prompt": "你是分镜导演。只输出 shot_list.v1，不生成视频。",
        "prompt": "根据 episode_script 生成 3-10 个 shot。",
        "input": "episode_inputs,episode_script",
        "optional_input": "shot_reply",
        "output": "shot_list_decision",
        "output_contract": "decision_envelope.v1"
      },
      "next": "match_assets",
      "layout": {
        "x": 740,
        "y": 240
      }
    },
    "match_assets": {
      "type": "process",
      "title": "匹配固定资产",
      "kind": "mcp_read",
      "executor": "mcp",
      "effect": "read_only",
      "protocol_version": "0.5",
      "input": "episode_script,shot_list",
      "output": "asset_plan",
      "tool_binding": "static_params",
      "allowed_tools": [
        "media_match_series_assets"
      ],
      "mcp_binding": {
        "mode": "read_only",
        "allowed_tools": [
          "media_match_series_assets"
        ]
      },
      "failure_policy": "fail_closed",
      "abort_on_failed": true,
      "audit_log": true,
      "params": {
        "input": "episode_script,shot_list",
        "output": "asset_plan"
      },
      "next": "match_actions",
      "layout": {
        "x": 984,
        "y": 136
      }
    },
    "match_actions": {
      "type": "process",
      "title": "匹配动作与摄影机",
      "kind": "mcp_read",
      "executor": "mcp",
      "effect": "read_only",
      "protocol_version": "0.5",
      "input": "episode_script,shot_list",
      "output": "action_plan",
      "tool_binding": "static_params",
      "allowed_tools": [
        "media_match_series_actions"
      ],
      "mcp_binding": {
        "mode": "read_only",
        "allowed_tools": [
          "media_match_series_actions"
        ]
      },
      "failure_policy": "fail_closed",
      "abort_on_failed": true,
      "audit_log": true,
      "params": {
        "input": "episode_script,shot_list",
        "output": "action_plan"
      },
      "next": "build_storyboard",
      "layout": {
        "x": 980,
        "y": 340
      }
    },
    "build_storyboard": {
      "type": "process",
      "title": "构建分镜项目",
      "kind": "mcp_execute",
      "executor": "mcp",
      "effect": "writes_artifacts",
      "protocol_version": "0.5",
      "input": "episode_script,shot_list,asset_plan,action_plan",
      "output": "storyboard_project",
      "tool_binding": "static_params",
      "allowed_tools": [
        "build_storyboard_project"
      ],
      "permission": "write_run_artifacts",
      "failure_policy": "fail_closed",
      "abort_on_failed": true,
      "audit_log": true,
      "params": {
        "input": "episode_script,shot_list,asset_plan,action_plan",
        "output": "storyboard_project",
        "tool_params": {
          "episode_script": "store:episode_script",
          "shot_list": "store:shot_list",
          "asset_plan": "store:asset_plan",
          "action_plan": "store:action_plan"
        }
      },
      "next": "render_storyboard",
      "layout": {
        "x": 1220,
        "y": 240
      }
    },
    "render_storyboard": {
      "type": "process",
      "title": "生成基础分镜帧",
      "kind": "mcp_execute",
      "executor": "mcp",
      "effect": "writes_artifacts",
      "protocol_version": "0.5",
      "input": "storyboard_project",
      "output": "storyboard_frame_bundle",
      "tool_binding": "static_params",
      "allowed_tools": [
        "render_storyboard_frames"
      ],
      "permission": "write_run_artifacts",
      "failure_policy": "fail_closed",
      "abort_on_failed": true,
      "audit_log": true,
      "params": {
        "input": "storyboard_project",
        "output": "storyboard_frame_bundle",
        "tool_params": {
          "storyboard_project": "store:storyboard_project"
        }
      },
      "next": "director_console",
      "layout": {
        "x": 1460,
        "y": 240
      }
    },
    "director_console": {
      "type": "process",
      "title": "分镜导演台",
      "kind": "ui",
      "executor": "deterministic",
      "effect": "none",
      "protocol_version": "0.5",
      "input": "storyboard_frame_bundle",
      "output": "director_console_view",
      "params": {
        "path": "dlc/frontend/director.html",
        "input": "storyboard_frame_bundle",
        "output": "director_console_view",
        "ui_type": "html"
      },
      "next": "review_storyboard",
      "layout": {
        "x": 1700,
        "y": 240
      }
    },
    "review_storyboard": {
      "type": "process",
      "title": "确认分镜构图",
      "kind": "human_gate",
      "executor": "human",
      "effect": "none",
      "protocol_version": "0.5",
      "input": "storyboard_frame_bundle",
      "output": "storyboard_review",
      "params": {
        "description": "导演台提交后才允许进入视频镜头准备。",
        "interaction": {
          "id": "director_storyboard_review",
          "ui_extension": "portable_dlc",
          "store_key": "director_reply",
          "prompt": "逐镜调整完成后提交并继续。",
          "input_schema": {
            "type": "object",
            "properties": {
              "approval": {
                "type": "string",
                "enum": [
                  "approve_all",
                  "revise"
                ]
              },
              "approved_shot_ids": {
                "type": "array"
              },
              "shot_changes": {
                "type": "array"
              }
            },
            "required": [
              "approval"
            ]
          },
          "resume_policy": "resume_same_node",
          "offline_answer": {
            "approval": "approve_all",
            "approved_shot_ids": [
              "shot_01",
              "shot_02",
              "shot_03"
            ],
            "shot_changes": []
          }
        },
        "input": "storyboard_frame_bundle",
        "output": "storyboard_review"
      },
      "next": "apply_adjustments",
      "layout": {
        "x": 1940,
        "y": 240
      }
    },
    "apply_adjustments": {
      "type": "process",
      "title": "保存导演调整",
      "kind": "mcp_execute",
      "executor": "mcp",
      "effect": "writes_artifacts",
      "protocol_version": "0.5",
      "input": "storyboard_frame_bundle,storyboard_review",
      "output": "approved_storyboard_project",
      "tool_binding": "static_params",
      "allowed_tools": [
        "apply_storyboard_adjustments"
      ],
      "permission": "write_run_artifacts",
      "failure_policy": "fail_closed",
      "abort_on_failed": true,
      "audit_log": true,
      "params": {
        "input": "storyboard_frame_bundle,storyboard_review",
        "output": "approved_storyboard_project",
        "tool_params": {
          "storyboard_project": "store:storyboard_frame_bundle",
          "review": "store:storyboard_review"
        }
      },
      "next": "render_approved_frames",
      "layout": {
        "x": 2180,
        "y": 240
      }
    },
    "render_approved_frames": {
      "type": "process",
      "title": "重绘确认后的分镜帧",
      "kind": "mcp_execute",
      "executor": "mcp",
      "effect": "writes_artifacts",
      "protocol_version": "0.5",
      "input": "approved_storyboard_project",
      "output": "approved_frame_bundle",
      "tool_binding": "static_params",
      "allowed_tools": [
        "render_storyboard_frames"
      ],
      "permission": "write_run_artifacts",
      "failure_policy": "fail_closed",
      "abort_on_failed": true,
      "audit_log": true,
      "params": {
        "input": "approved_storyboard_project",
        "output": "approved_frame_bundle",
        "tool_params": {
          "storyboard_project": "store:approved_storyboard_project"
        }
      },
      "next": "prepare_video",
      "layout": {
        "x": 2420,
        "y": 240
      }
    },
    "prepare_video": {
      "type": "process",
      "title": "生成视频镜头包",
      "kind": "mcp_execute",
      "executor": "mcp",
      "effect": "writes_artifacts",
      "protocol_version": "0.5",
      "input": "approved_storyboard_project",
      "output": "video_shot_package",
      "tool_binding": "static_params",
      "allowed_tools": [
        "prepare_video_shots"
      ],
      "permission": "write_run_artifacts",
      "failure_policy": "fail_closed",
      "abort_on_failed": true,
      "audit_log": true,
      "params": {
        "input": "approved_storyboard_project",
        "output": "video_shot_package",
        "tool_params": {
          "storyboard_project": "store:approved_storyboard_project"
        }
      },
      "next": "delivery_summary",
      "layout": {
        "x": 2660,
        "y": 240
      }
    },
    "delivery_summary": {
      "type": "process",
      "title": "交付分镜镜头包",
      "kind": "delivery",
      "executor": "deterministic",
      "effect": "writes_store",
      "protocol_version": "0.5",
      "input": "episode_script,shot_list,asset_plan,action_plan,approved_storyboard_project,approved_frame_bundle,video_shot_package",
      "output": "series_delivery",
      "primary_output": "series_delivery",
      "params": {
        "input": "episode_script,shot_list,asset_plan,action_plan,approved_storyboard_project,approved_frame_bundle,video_shot_package",
        "output": "series_delivery",
        "preset_config": {
          "items": "episode_script,shot_list,asset_plan,action_plan,approved_storyboard_project,approved_frame_bundle,video_shot_package",
          "output_name": "series_delivery"
        }
      },
      "next": "delivery",
      "layout": {
        "x": 2900,
        "y": 240
      }
    },
    "delivery": {
      "type": "system",
      "title": "交付",
      "action": "delivery",
      "next": "complete",
      "layout": {
        "x": 3140,
        "y": 240
      }
    },
    "complete": {
      "type": "terminal",
      "title": "流程完成",
      "layout": {
        "x": 3380,
        "y": 240
      }
    }
  },
