              "approved_shot_ids": {
                "type": "array"
              },
              "shot_changes": {
                "type": "array"
              }
            },
            "required": [
              "approval"
            ]
          },
          "resume_policy": "resume_same_node",
          "offline_answer": {
            "approval": "approve_all",
            "approved_shot_ids": [
              "shot_01",
              "shot_02",
              "shot_03"
            ],
            "shot_changes": []
          }
        },
        "input": "storyboard_frame_bundle",
        "output": "storyboard_review"
      },
      "next": "apply_adjustments",
      "layout": {
        "x": 2180,
        "y": 240
