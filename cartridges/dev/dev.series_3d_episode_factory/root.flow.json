      "scope": "root"
    },
    {
      "from": "collect_brief",
      "to": "write_script",
      "scope": "root"
    },
    {
      "from": "write_script",
      "to": "plan_shots",
      "scope": "root"
    },
    {
      "from": "plan_shots",
