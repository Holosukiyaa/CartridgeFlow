{
  "schema_version": 1,
  "id": "dev.series_3d_episode_factory.root.v2",
  "name": "3D 系列短剧分镜工作流",
  "mode": "lifecycle",
  "cartridge_id": "dev.series_3d_episode_factory",
  "protocol": {
    "id": "CF-FARP",
    "version": "0.5"
  },
  "start": "start",
  "states": {
    "start": {
      "type": "system",
      "title": "开始",
      "action": "start",
      "next": "collect_brief",
      "layout": {
        "x": 9,
        "y": 239
      }
    },
    "collect_brief": {
      "type": "process",
      "title": "填写创作需求",
      "kind": "input",
      "executor": "user",
      "effect": "writes_store",
      "protocol_version": "0.5",
      "input_kind": "episode_brief",
      "source": "run_inputs",
      "output": "episode_inputs",
      "input_schema": {
        "type": "object",
        "fields": [
          "episode_brief"
        ]
      },
      "params": {
        "description": "输入本集的故事想法。",
        "fields": [
          "episode_brief"
        ],
        "output": "episode_inputs"
      },
      "next": "write_script",
      "layout": {
        "x": 260,
        "y": 240
      }
    },
    "write_script": {
      "type": "process",
      "title": "AI 生成剧情",
      "kind": "decision",
      "executor": "llm",
      "effect": "none",
      "protocol_version": "0.5",
      "input": "episode_inputs",
      "optional_input": "script_reply",
      "output": "episode_script_decision",
      "output_contract": "decision_envelope.v1",
      "abort_on_failed": true,
      "decision_contract": {
        "schema": "decision_envelope.v1",
        "allowed_statuses": [
          "resolved",
          "needs_user_input",
          "blocked"
        ],
        "on_needs_user_input": "pause",
        "interaction": {
          "store_key": "script_reply",
          "input_schema": {
            "type": "object",
            "properties": {
              "approval": {
                "type": "string",
                "enum": [
                  "approve",
                  "revise"
                ]
              },
              "feedback": {
                "type": "string"
              }
            },
            "required": [
              "approval"
            ]
          },
          "resume_policy": "resume_same_node",
          "live_collaboration": true
        },
        "consume": {
          "mode": "payload_path",
          "path": "payload.episode_script",
          "as": "episode_script",
          "on_missing": "fail_closed"
        },
        "offline_decision": {
          "schema": "decision_envelope.v1",
          "status": "resolved",
          "summary": "离线剧情草案",
          "payload": {
            "episode_script": {
              "schema": "episode_script.v1",
              "title": "街角的回声",
              "episode_id": "pilot_suburban_ep01",
              "genre": "urban_suspense",
              "format": "vertical_short",
              "duration_target": 30,
              "hook": "男孩在空街上听见第二个脚步声。",
              "logline": "一个男孩沿着白天的街道前进，停下后发现声音来自自己的影子。",
              "beats": [
                "男孩向前走过街道",
                "他停下观察四周",
                "影子做出不同步的动作"
              ],
              "dialogue": [],
              "ending_hook": "影子先一步走进拐角"
            }
          }
        }
      },
      "params": {
        "description": "只生成剧情和节奏，不生成美术资产。",
        "system_prompt": "你是系列短剧编剧。只输出 decision_envelope.v1 的 episode_script.v1。",
        "prompt": "根据 episode_inputs 生成 episode_script.v1。",
        "input": "episode_inputs",
        "optional_input": "script_reply",
        "output": "episode_script_decision",
        "output_contract": "decision_envelope.v1"
      },
      "next": "plan_shots",
      "layout": {
        "x": 500,
        "y": 240
      }
    },
    "plan_shots": {
      "type": "process",
      "title": "AI 拆解分镜",
      "kind": "decision",
      "executor": "llm",
      "effect": "none",
      "protocol_version": "0.5",
      "input": "episode_inputs,episode_script",
      "optional_input": "shot_revision_feedback",
      "output": "shot_list_decision",
      "output_contract": "decision_envelope.v1",
      "abort_on_failed": true,
      "decision_contract": {
        "schema": "decision_envelope.v1",
        "allowed_statuses": [
          "resolved",
          "needs_user_input",
          "blocked"
        ],
        "on_needs_user_input": "pause",
        "interaction": {
          "store_key": "shot_reply",
          "input_schema": {
            "type": "object",
            "properties": {
              "approval": {
                "type": "string",
                "enum": [
                  "approve",
                  "revise"
                ]
              },
              "feedback": {
                "type": "string"
              }
            },
            "required": [
              "approval"
            ]
          },
          "resume_policy": "resume_next_node",
          "answer_routes": [
            {
              "match": {"field": "approval", "equals": "revise"},
              "policy": "resume_same_node",
              "copy_answer_to": "shot_revision_feedback",
              "clear_store_keys": ["shot_reply"]
            }
          ],
          "live_collaboration": true
        },
        "consume": {
          "mode": "payload_path",
          "path": "payload.shot_list",
          "as": "shot_list_candidate",
          "on_missing": "fail_closed"
        },
        "offline_decision": {
          "schema": "decision_envelope.v1",
          "status": "resolved",
          "summary": "离线分镜草案",
          "payload": {
            "shot_list": {
              "schema": "shot_list.v1",
              "shots": [
                {
                  "id": "shot_01",
                  "title": "街道前进",
                  "description": "男孩沿着白天的郊区街道向前走。",
                  "scene_design": {
                    "location": "白天郊区街道入口",
                    "time": "day",
                    "weather": "clear",
                    "landmarks": ["左侧住宅", "右侧行道树", "远处拐角"],
                    "blocking_notes": "人物从画面深处进入，街道透视线指向远处拐角。"
                  },
                  "characters": [
                    "hero"
                  ],
                  "props": [],
                  "action_tags": [
                    "walk_slow"
                  ],
                  "camera": {
                    "template": "slow_push_in",
                    "position": [-1.4, -8.5, 2.4],
                    "target": [0.0, 1.0, 1.2],
                    "focal_length_mm": 36
                  },
                  "actor_blocking": [
                    {"actor_id": "hero", "position": [-0.7, 1.6, 0.0], "rotation_degrees": [0.0, 0.0, 8.0], "action": "walk_slow", "pose_time": 0.18}
                  ],
                  "lighting": {"key": "sun_left", "exposure": 0.15},
                  "duration": 5
                },
                {
                  "id": "shot_02",
                  "title": "停下观察",
                  "description": "男孩停下脚步，侧头听向身后。",
                  "scene_design": {
                    "location": "住宅前的人行道",
                    "time": "day",
                    "weather": "clear",
                    "landmarks": ["路边围墙", "住宅窗户", "身后空路"],
                    "blocking_notes": "让背景留出声音来源方向，人物侧脸占画面中心。"
                  },
                  "characters": [
                    "hero"
                  ],
                  "props": [],
                  "action_tags": [
                    "idle_hold"
                  ],
                  "camera": {
                    "template": "close_up_reveal",
                    "position": [2.2, -3.6, 1.75],
                    "target": [-0.5, 1.1, 1.45],
                    "focal_length_mm": 68
                  },
                  "actor_blocking": [
                    {"actor_id": "hero", "position": [-0.5, 1.1, 0.0], "rotation_degrees": [0.0, 0.0, -35.0], "action": "look_back", "pose_time": 0.52}
                  ],
                  "lighting": {"key": "sun_rim", "exposure": 0.05},
                  "duration": 5
                },
                {
                  "id": "shot_03",
                  "title": "影子异动",
                  "description": "男孩抬头，影子在地面上先一步转向拐角。",
                  "scene_design": {
                    "location": "街道尽头拐角",
                    "time": "late_afternoon",
                    "weather": "clear",
                    "landmarks": ["高围墙", "转角路灯", "拉长的地面阴影"],
                    "blocking_notes": "低机位同时看见人物和偏离人物动作的影子。"
                  },
                  "characters": [
                    "hero"
                  ],
                  "props": [],
                  "action_tags": [
                    "gesture_interact"
                  ],
                  "camera": {
                    "template": "low_angle_hold",
                    "position": [1.2, -4.8, 0.55],
                    "target": [0.2, 1.8, 1.0],
                    "focal_length_mm": 32
                  },
                  "actor_blocking": [
                    {"actor_id": "hero", "position": [0.6, 1.8, 0.0], "rotation_degrees": [0.0, 0.0, 42.0], "action": "gesture_interact", "pose_time": 0.76}
                  ],
                  "lighting": {"key": "low_sun", "exposure": -0.1},
                  "duration": 5
                }
              ]
            }
          }
        }
      },
      "params": {
        "description": "以镜头为单位生成可编辑的构图、动作和节奏草案。",
        "system_prompt": "你是分镜导演。只输出 decision_envelope.v1，不生成视频。首次方案或收到修改意见时，status 必须为 needs_user_input，并把完整 shot_list.v1 放在 payload.draft_shot_list；不要把 question 放进 payload。若不需要用户确认而直接 resolved，则把完整 shot_list.v1 放在 payload.shot_list。每个 shot 必须包含 id、title、description、duration、scene_design、camera、actor_blocking、action_tags、lighting、composition。scene_design 必须包含 location、time、weather、landmarks、blocking_notes；camera 必须包含 template、position、target、focal_length_mm；actor_blocking 必须是数组，每个出镜人物分别包含 actor_id、position、rotation_degrees、action、pose_time。每个镜头都要给出有叙事目的的独立构图、机位、人物站位和默认动作相位，连续场景也不能简单复制上一镜。",
        "prompt": "根据 episode_script 生成 3-10 个可直接进入 3D 导演台的 shot。先设计每镜空间与构图，再确定机位、人物阻挡和动作；如果存在 shot_revision_feedback，必须据此修改后重新给出完整草稿并请求确认。",
        "input": "episode_inputs,episode_script",
        "optional_input": "shot_revision_feedback",
        "output": "shot_list_decision",
        "output_contract": "decision_envelope.v1"
      },
      "next": "confirm_shot_plan",
      "layout": {
        "x": 740,
        "y": 240
      }
    },
    "confirm_shot_plan": {
      "type": "process",
      "title": "确认分镜方案数据",
      "kind": "mcp_read",
