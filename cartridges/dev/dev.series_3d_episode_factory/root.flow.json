      "effect": "read_only",
      "protocol_version": "0.5",
      "input": "shot_list_decision",
      "optional_input": "shot_reply",
      "output": "shot_list",
      "tool_binding": "static_params",
      "allowed_tools": [
        "confirm_storyboard_plan"
      ],
      "mcp_binding": {
        "mode": "read_only",
        "allowed_tools": [
          "confirm_storyboard_plan"
        ]
      },
      "failure_policy": "fail_closed",
      "abort_on_failed": true,
      "audit_log": true,
      "params": {
        "input": "shot_list_decision",
        "optional_input": "shot_reply",
        "output": "shot_list",
        "tool_params": {
          "shot_list_decision": "store:shot_list_decision",
          "shot_reply": "store:shot_reply"
        }
