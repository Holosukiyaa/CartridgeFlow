{
  "schema_version": "1.0",
  "id": "dev.spatial_blockout_lab",
  "name": "3D 草图实验室卡带",
  "version": "0.1.0-dev",
  "kind": "runtime_cartridge",
  "category": "dev_flow",
  "description": "轻量 3D blockout 草图卡带：用户输入空间想法，AI 转为 scene_blockout.v1 结构，本地工具生成 GLB、场景 JSON、manifest 和 HTML 预览，用于验证 3D 工作流方向。",
  "publisher": {
    "id": "local",
    "name": "Local Developer",
    "type": "local",
    "verified": false
  },
  "branding": {
    "tags": [
      "3d",
      "blockout",
      "glb",
      "spatial",
      "cf-farp",
      "protocol-v0.4"
    ]
  },
  "base_contract": {
    "id": "CF-FARP",
    "version": "0.4",
    "declared_for": "cartridgeflow.reference-dev",
    "compatibility_mode": "protocol_aware"
  },
  "runtime_contract": {
    "protocol": "CF-FARP",
    "protocol_version": "0.4",
    "required_profiles": [
      "runtime_core",
      "dynamic_decision_runtime",
      "interactive_decision_runtime"
    ],
    "recommended_profiles": [
      "testbench_core",
      "dev_authoring"
    ],
    "required_capabilities": [
      "manifest_load",
      "manifest_validate",
      "runtime_contract_parse",
      "compatibility_report",
      "root_flow_execution",
      "basic_node_execution",
      "unified_process_node",
      "process_node_kind_parse",
      "process_executor_contract",
      "process_effect_contract",
      "decision_process",
      "mcp_execute_process",
      "decision_envelope_v1",
      "decision_envelope_validate",
      "decision_consume_contract",
      "decision_consume_projection",
      "llm_live_mode",
      "llm_mock_mode",
      "llm_offline_fallback",
      "runtime_user_input_request",
      "paused_waiting_user_status",
      "pending_interaction_record",
      "runtime_resume_after_user_input",
      "builtin_tool_call",
      "artifact_collect",
      "delivery_readiness_check",
      "optional_input"
    ],
    "optional_capabilities": [
      "artifact_preview",
      "testbench_run",
      "probe_run",
      "structure_analysis",
      "data_chain_diagnostics"
    ],
    "required_tools": [
      "media_forge_spatial_blockout"
    ],
    "optional_tools": []
  },
  "protocol_certification": {
    "status": "certified",
    "label": "CF-FARP@0.4",
    "protocol": "CF-FARP",
    "protocol_version": "0.4"
  },
  "delivery_readiness": {
    "level": "dev",
    "certification_target": "CF-FARP@0.4",
    "notes": "开发预览卡带。产物是 3D 草图，不是最终美术资产。"
  },
  "root_flow": {
    "entry": "root.flow.json",
    "mode": "lifecycle",
    "required": true
  },
  "runtime": {
    "type": "lab",
    "adapter": "builtin:lab"
  },
  "workspace": {
    "type": "none",
    "required": false,
    "open_policy": "manual"
  },
  "environment": {
    "os": [
      "windows",
      "macos",
      "linux"
    ],
    "requires": []
  },
  "permissions": [
    {
      "id": "write_run_artifacts",
      "level": "safe",
      "description": "写入 test_output/spatial_blockout 下的 GLB、scene JSON、manifest 和 HTML 预览。"
    }
  ],
  "dependencies": [],
  "inputs": [
    {
      "id": "scene_brief",
      "label": "3D 场景想法",
      "type": "textarea",
      "required": true,
      "placeholder": "例如：一个蓝色夹克少年站在废弃地铁站入口，远处有红色警示灯。"
    },
    {
      "id": "scene_id",
      "label": "场景 ID",
      "type": "text",
      "required": false,
      "placeholder": "subway_blockout"
    },
    {
      "id": "style_notes",
      "label": "风格备注",
      "type": "textarea",
      "required": false,
      "placeholder": "低模、粗模、可读性优先、不要细节材质。"
    },
    {
      "id": "output_dir",
      "label": "输出目录",
      "type": "text",
      "required": false,
      "default": "test_output/spatial_blockout"
    }
  ],
  "outputs": [
    {
      "id": "spatial_delivery",
      "label": "3D 草图交付包",
      "type": "artifact_bundle",
      "required": true
    }
  ],
  "mcp_tools": [
    {
      "id": "media_forge_spatial_blockout",
      "name": "Media 3D 草图生成",
      "type": "builtin",
      "server": "media",
      "tool": "forge_spatial_blockout",
      "description": "消费 scene_blockout.v1，生成 GLB、场景 JSON、manifest 和离线 HTML 预览。",
      "default_params": {
        "scene_spec": "store:scene_blockout",
        "output_dir": "store:scene_inputs.output_dir",
        "filename_prefix": "store:scene_inputs.scene_id"
      },
      "enabled": true,
      "required": true,
      "contract": {
        "capability": "builtin_tool_call",
        "idempotent": true,
        "side_effect": "writes_run_artifacts",
        "timeout_ms": 30000,
        "retry_policy": {
          "max_attempts": 1
        }
      },
      "params_schema": {
        "type": "object",
        "properties": {
          "scene_spec": {
            "type": [
              "object",
              "string"
            ]
          },
          "output_dir": {
            "type": "string"
          },
          "filename_prefix": {
            "type": "string"
          }
        },
        "required": [
          "scene_spec"
        ],
        "additionalProperties": true
      }
    }
  ],
  "artifacts": {
    "store_policy": "run_scoped",
    "visibility_default": "user",
    "allowed_types": [
      "json",
      "html",
      "model"
    ]
  },
  "delivery": {
    "type": "summary_with_artifacts",
    "primary_output": "spatial_delivery",
    "show_artifacts": true
  }
}
