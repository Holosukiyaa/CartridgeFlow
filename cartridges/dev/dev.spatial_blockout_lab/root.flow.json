{
  "schema_version": 1,
  "id": "dev.spatial_blockout_lab.root.v1",
  "name": "3D 动画预演实验室 RootFlow",
  "mode": "standard",
  "cartridge_id": "dev.spatial_blockout_lab",
  "protocol": {
    "id": "CF-FARP",
    "version": "0.4"
  },
  "start": "start",
  "states": {
    "start": {
      "type": "system",
      "title": "开始",
      "action": "start",
      "layout": {
        "x": 60,
        "y": 180
      },
      "next": "welcome_ui"
    },
    "welcome_ui": {
      "type": "process",
      "title": "工程看板：3D 动画预演实验室",
      "action": "show_ui",
      "kind": "ui",
      "executor": "deterministic",
      "effect": "writes_store",
      "protocol_version": "0.4",
      "display": {
        "suffix": "展示",
        "label": "展示节点"
      },
      "output": "welcome_ui",
      "params": {
        "description": "展示 3D 动画预演卡带入口。",
        "output": "welcome_ui",
        "ui_type": "html",
        "path": "assets/welcome.html"
      },
      "layout": {
        "x": 350,
        "y": 180
      },
      "next": "collect_scene_brief"
    },
    "collect_scene_brief": {
      "type": "process",
      "title": "入料口：3D 动画想法",
      "kind": "input",
      "executor": "user",
      "effect": "writes_store",
      "protocol_version": "0.4",
      "display": {
        "suffix": "输入",
        "label": "输入节点"
      },
      "input_kind": "initial",
      "source": "user_form",
      "input_schema": {
        "schema": "spatial_animation.input.v1",
        "fields": [
          "scene_brief",
          "scene_id",
          "style_notes",
          "output_dir"
        ]
      },
      "output": "scene_inputs",
      "params": {
        "description": "收集用户对 3D 动画预演的空间、角色、动作、镜头、前中后景和输出目录要求。",
        "output": "scene_inputs"
      },
      "layout": {
        "x": 660,
        "y": 180
      },
      "next": "decide_scene_blockout"
    },
    "decide_scene_blockout": {
      "type": "process",
      "title": "AI决策：生成 3D 动画预演规格",
      "kind": "decision",
      "executor": "llm",
      "effect": "none",
      "protocol_version": "0.4",
      "display": {
        "suffix": "AI决策",
        "label": "AI决策节点"
      },
      "input": "scene_inputs",
      "optional_input": "scene_plan_reply,blockout_rework_feedback",
      "output": "scene_blockout_decision",
      "output_contract": "decision_envelope.v1",
      "decision_contract": {
        "schema": "decision_envelope.v1",
        "allowed_statuses": [
          "resolved",
          "needs_user_input",
          "blocked"
        ],
        "on_needs_user_input": "pause",
        "interaction": {
          "store_key": "scene_plan_reply",
          "input_schema": {
            "type": "object",
            "properties": {
              "approval": {
                "type": "string",
                "title": "规格确认",
                "enum": [
                  "approve",
                  "revise"
                ],
                "enumNames": [
                  "确认生成",
                  "修改规格"
                ]
              },
              "feedback": {
                "type": "string",
                "title": "修改意见",
                "description": "如果选择修改规格，请说明需要调整的空间、角色、道具、镜头或风格。"
              }
            },
            "required": [
              "approval"
            ]
          },
          "resume_policy": "resume_same_node",
          "live_collaboration": true
        },
        "consume": {
          "mode": "payload_path",
          "path": "payload.scene_blockout",
          "as": "scene_blockout",
          "on_missing": "fail_closed"
        },
        "offline_decision": {
          "schema": "decision_envelope.v1",
          "status": "resolved",
          "summary": "离线兜底：生成一个可执行的低模 3D 动画预演规格。",
          "payload": {
            "scene_blockout": {
              "schema": "scene_animation.v1",
              "title": "废弃地铁站入口 3D 动画预演",
              "style": "low_poly_animation_previz",
              "objects": [
                {
                  "id": "ground",
                  "type": "ground",
                  "name": "地面基准",
                  "position": [
                    0,
                    0,
                    0
                  ],
                  "size": [
                    7,
                    0.08,
                    5
                  ],
                  "color": "gray",
                  "layer": "background",
                  "depth_order": 0
                },
                {
                  "id": "hero",
                  "type": "character",
                  "name": "蓝色夹克少年",
                  "position": [
                    0,
                    0,
                    0
                  ],
                  "color": "blue",
                  "layer": "foreground",
                  "depth_order": 200
                },
                {
                  "id": "subway_entrance",
                  "type": "entrance",
                  "name": "废弃地铁站入口",
                  "position": [
                    0,
                    0,
                    1.7
                  ],
                  "size": [
                    2.8,
                    2.4,
                    0.28
                  ],
                  "color": "wall",
                  "layer": "midground",
                  "depth_order": 100
                },
                {
                  "id": "warning_light",
                  "type": "warning_light",
                  "name": "红色警示灯",
                  "position": [
                    2.2,
                    1.5,
                    -0.9
                  ],
                  "color": "red",
                  "layer": "background",
                  "depth_order": 20
                }
              ],
              "camera": {
                "position": [
                  4.5,
                  3.8,
                  6
                ],
                "look_at": [
                  0,
                  0.8,
                  0
                ],
                "lens_mm": 32,
                "movement": "slow_push_in",
                "distance": "medium_close",
                "focus_target": "hero"
              },
              "timeline": {
                "duration_seconds": 6,
                "fps": 24,
                "tracks": [
                  {
                    "target": "hero",
                    "property": "offset",
                    "keyframes": [
                      {
                        "time": 0,
                        "value": [
                          -0.7,
                          0,
                          0.35
                        ]
                      },
                      {
                        "time": 2.8,
                        "value": [
                          0,
                          0,
                          0
                        ]
                      },
                      {
                        "time": 6,
                        "value": [
                          0.15,
                          0,
                          -0.08
                        ]
                      }
                    ]
                  },
                  {
                    "target": "hero",
                    "property": "pose",
                    "keyframes": [
                      {
                        "time": 0,
                        "value": "walk"
                      },
                      {
                        "time": 3,
                        "value": "smoke"
                      },
                      {
                        "time": 6,
                        "value": "idle"
                      }
                    ]
                  },
                  {
                    "target": "warning_light",
                    "property": "pulse",
                    "keyframes": [
                      {
                        "time": 0,
                        "value": 0.2
                      },
                      {
                        "time": 3,
                        "value": 1
                      },
                      {
                        "time": 6,
                        "value": 0.35
                      }
                    ]
                  }
                ],
                "events": [
                  {
                    "time": 3.4,
                    "type": "smoke_puff",
                    "target": "hero",
                    "label": "少年抽烟"
                  },
                  {
                    "time": 4.6,
                    "type": "warning_light",
                    "target": "warning_light",
                    "label": "红灯闪烁"
                  }
                ]
              },
              "notes": "低模动画预演，只验证动作节奏、镜头推进、角色站位、前中后景层次和关键事件。",
              "composition": {
                "schema": "scene_composition.v1",
                "goal": "让前景主角、中景建筑和远景线索一眼可分。",
                "foreground": [
                  "hero"
                ],
                "midground": [
                  "subway_entrance"
                ],
                "background": [
                  "ground",
                  "warning_light"
                ],
                "focus": [
                  "hero",
                  "warning_light"
                ],
                "subject_scale": "hero_dominant",
                "depth_rules": [
                  "hero 必须始终是最清楚的主体。",
                  "subway_entrance 作为中景建筑，不得压过 hero。",
                  "warning_light 只做远景线索，不得抢占画面中心。"
                ],
                "notes": "让前中后景先可读，再谈细节。"
              }
            }
          }
        }
      },
      "params": {
        "description": "把用户的自然语言需求转成 scene_animation.v1。先让用户确认动作、镜头和前中后景层次，再允许工具写入产物。",
        "system_prompt": "你是 3D 动画预演导演，只负责把想法转成可执行的低模动画规格。不要追求最终建模质量，要追求动作节奏、镜头调度、角色站位、前景/中景/背景层次和关键事件清楚。",
        "prompt": "根据 scene_inputs 生成 scene_animation.v1，并放在 payload.scene_blockout 中以供现有工具消费。必须输出 decision_envelope.v1。resolved 时 payload.scene_blockout 必须包含：schema='scene_animation.v1'、title、style、composition、objects、camera、timeline、notes。composition 至少要说明 goal、foreground、midground、background、focus、depth_rules、subject_scale。objects 是低模代理对象，字段至少包含 id/type/name/position/size/color/layer/depth_order；必要时补充 role、anchor。camera 必须包含 position、look_at、lens_mm、movement、distance 或 framing、focus_target。timeline 必须包含 duration_seconds、tracks、events；tracks 至少包含主角位移或姿态、关键道具闪烁或运动，且要能看出前景/中景/背景关系。position/size 是 [x,y,z]，y 为垂直高度。对象数量控制在 4-12 个，前景、中景、背景必须一眼可分。若用户在 scene_plan_reply 或 blockout_rework_feedback 中要求修改，请吸收修改后再 resolved。",
        "input": "scene_inputs",
        "optional_input": "scene_plan_reply,blockout_rework_feedback",
        "output": "scene_blockout_decision",
        "output_contract": "decision_envelope.v1"
      },
      "layout": {
        "x": 980,
        "y": 180
      },
      "next": "forge_blockout"
    },
    "forge_blockout": {
      "type": "process",
      "title": "动画预演工坊：生成可播放 3D 预览",
      "kind": "mcp_execute",
      "executor": "mcp",
      "effect": "writes_artifacts",
      "protocol_version": "0.4",
      "display": {
        "suffix": "MCP执行",
        "label": "MCP执行节点"
      },
      "tool_binding": "static_params",
      "allowed_tools": [
        "media_forge_spatial_blockout"
      ],
      "permission": "write_run_artifacts",
      "failure_policy": "fail_closed",
      "audit_log": true,
      "input": "scene_blockout",
      "output": "blockout_bundle",
      "params": {
        "description": "消费 scene_animation.v1，生成 GLB 代理、动画 JSON、manifest 和可播放 HTML 预览，并保留 composition/layer/camera 结构。",
        "input": "scene_blockout",
        "output": "blockout_bundle",
        "tool_params": {
          "scene_spec": "store:scene_blockout",
          "title": "store:scene_blockout.title",
          "output_dir": "store:scene_inputs.output_dir",
          "filename_prefix": "store:scene_inputs.scene_id"
        }
      },
      "layout": {
        "x": 1366,
        "y": 313
      },
      "next": "review_blockout"
    },
    "review_blockout": {
      "type": "process",
      "title": "AI决策：动画预演复核",
      "kind": "decision",
      "executor": "llm",
      "effect": "none",
      "protocol_version": "0.4",
      "display": {
        "suffix": "AI决策",
        "label": "AI决策节点"
      },
      "input": "scene_inputs,scene_blockout,blockout_bundle",
      "optional_input": "blockout_review_reply",
      "output": "blockout_review_decision",
      "output_contract": "decision_envelope.v1",
      "decision_contract": {
        "schema": "decision_envelope.v1",
        "allowed_statuses": [
          "resolved",
          "needs_user_input",
          "blocked"
        ],
        "on_needs_user_input": "pause",
        "interaction": {
          "store_key": "blockout_review_reply",
          "input_schema": {
            "type": "object",
            "properties": {
              "approval": {
                "type": "string",
                "title": "草图复核",
                "enum": [
                  "approve",
                  "revise"
                ],
                "enumNames": [
                  "通过",
                  "不满意，重做"
                ]
              },
              "feedback": {
                "type": "string",
                "title": "调整意见",
                "description": "如果不满意，请说明需要改动的对象、比例、空间、镜头或颜色。"
              }
            },
            "required": [
              "approval"
            ]
          },
          "resume_policy": "resume_same_node",
          "live_collaboration": true,
          "answer_routes": [
            {
              "match": {
                "field": "approval",
                "equals": "revise"
              },
              "target_node": "decide_scene_blockout",
              "policy": "resume_target_node",
              "replay_from_target": true,
              "copy_answer_to": "blockout_rework_feedback",
              "clear_store_keys": [
                "scene_plan_reply",
                "scene_blockout_decision",
                "scene_blockout",
                "blockout_bundle",
                "blockout_review_reply",
                "blockout_review_decision",
                "blockout_review",
                "spatial_delivery"
              ]
            }
          ]
        },
        "consume": {
          "mode": "payload_path",
          "path": "payload.review",
          "as": "blockout_review",
          "on_missing": "fail_closed"
        },
        "offline_decision": {
          "schema": "decision_envelope.v1",
          "status": "resolved",
          "summary": "离线兜底：草图可作为空间验证稿进入交付。",
          "payload": {
            "review": {
              "schema": "blockout_review.v1",
              "approved": true,
              "notes": "离线兜底自动通过。正式协作模式应由用户查看预览后确认。"
            }
          }
        }
      },
      "params": {
        "description": "让用户查看动画 HTML 预览后确认动作、镜头和节奏是否通过；不满意则回到规格节点局部重做。",
        "system_prompt": "你是 3D 动画预演复核助手。你的任务是根据用户复核意见决定通过或重做，不要直接执行工具。",
        "prompt": "若 optional_input blockout_review_reply 不存在，必须输出 needs_user_input，提醒用户打开动画预览后选择通过或重做。若用户 approval=revise 或文本表示不满意，输出 needs_user_input 或遵循 answer_routes 回到 decide_scene_blockout；若用户 approval=approve，输出 resolved，并在 payload.review 中写入 {schema:'blockout_review.v1', approved:true, notes:string}。",
        "input": "scene_inputs,scene_blockout,blockout_bundle",
        "optional_input": "blockout_review_reply",
        "output": "blockout_review_decision",
        "output_contract": "decision_envelope.v1"
      },
      "layout": {
        "x": 1605,
        "y": 57
      },
      "next": "delivery_summary"
    },
    "delivery_summary": {
      "type": "process",
      "title": "交付汇总：3D 动画预演包",
      "kind": "delivery",
      "executor": "deterministic",
      "effect": "writes_store",
      "protocol_version": "0.4",
      "display": {
        "suffix": "交付",
        "label": "交付节点"
      },
      "input": "scene_inputs,scene_blockout,blockout_bundle,blockout_review",
      "output": "spatial_delivery",
      "primary_output": "spatial_delivery",
      "params": {
        "description": "汇总输入、AI 规格、工具产物和用户复核结果。",
        "input": "scene_inputs,scene_blockout,blockout_bundle,blockout_review",
        "output": "spatial_delivery",
        "preset_config": {
          "items": "scene_inputs,scene_blockout,blockout_bundle,blockout_review",
          "output_name": "spatial_delivery"
        }
      },
      "layout": {
        "x": 1970,
        "y": 180
      },
      "next": "delivery"
    },
    "delivery": {
      "type": "system",
      "title": "交付",
      "action": "delivery",
      "layout": {
        "x": 2290,
        "y": 180
      },
      "next": "complete"
    },
    "complete": {
      "type": "terminal",
      "title": "完成",
      "layout": {
        "x": 2580,
        "y": 180
      }
    }
  },
  "edges": [
    {
      "from": "start",
      "to": "welcome_ui",
      "scope": "root"
    },
    {
      "from": "welcome_ui",
      "to": "collect_scene_brief",
      "scope": "root"
    },
    {
      "from": "collect_scene_brief",
      "to": "decide_scene_blockout",
      "scope": "root"
    },
    {
      "from": "decide_scene_blockout",
      "to": "forge_blockout",
      "scope": "root"
    },
    {
      "from": "forge_blockout",
      "to": "review_blockout",
      "scope": "root"
    },
    {
      "from": "review_blockout",
      "to": "delivery_summary",
      "scope": "root"
    },
    {
      "from": "delivery_summary",
      "to": "delivery",
      "scope": "root"
    },
    {
      "from": "delivery",
      "to": "complete",
      "scope": "root"
    }
  ]
}